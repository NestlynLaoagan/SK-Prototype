rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * Checks if the requesting user is an administrator by checking for their
     * existence in the /admins collection. This is more performant and secure
     * than checking a role field on a user document for list operations.
     */
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // User Data Collection
    match /users/{userId} {
      allow get, update: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId);
      allow list, delete: if isAdmin();
    }

    // Admin Roles Collection
    match /admins/{adminId} {
      // Admins can see who else is an admin or demote them.
      allow read, list, delete: if isAdmin();
      
      // A user can create their own document in the admins collection.
      // This is gated by application logic in the Admin Login and Roles pages 
      // to prevent any user from making themselves an admin.
      allow create: if request.auth.uid == adminId;
    }

    // Public Content Collections
    match /announcements/{announcementId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }
    
    match /events/{eventId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /faqs/{faqId} {
        allow get, list: if true;
        allow create, update, delete: if isAdmin();
    }

    match /projects/{projectId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    // User-Owned Subcollections
    match /users/{userId}/feedback/{feedbackId} {
      allow create: if isOwner(userId);
      allow read, update, delete: if isOwner(userId) || isAdmin();
    }

    // Rule for collection group query on 'feedback'
    match /{path=**}/feedback/{feedbackId} {
      allow list: if isAdmin();
    }

    // Admin-Only Collections
    match /logs/{logId} {
      allow read, write: if isAdmin();
    }

    match /archives/{archiveId} {
      allow read, write: if isAdmin();
    }
  }
}
