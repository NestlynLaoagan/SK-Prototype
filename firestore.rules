/**
 * This ruleset implements a hybrid security model for the BarangayConnect application.
 * It combines path-based ownership for user data with a global role-based system for administrative actions.
 * - Admin checks are performed by reading the `role` field from the user's profile document in the `/users` collection.
 * - Public data (projects, announcements, faqs) is readable by anyone.
 * - All write operations are restricted to administrators, except for users modifying their own data.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ----------------------------------------------------------------------
    // Helper Functions
    // ----------------------------------------------------------------------
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * Checks if the requesting user is an administrator.
     * It reads the user's profile from the `/users` collection to check their role.
     */
    function isAdmin() {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isExistingDoc() {
      return resource != null;
    }

    // ----------------------------------------------------------------------
    // User Data Collection
    // ----------------------------------------------------------------------
    /**
     * @description Manages user profile data.
     * @allow (get, update) The document owner or an admin.
     * @allow (create) An authenticated user creating their own document.
     * @allow (list, delete) Admins only.
     * @principle Protects PII while allowing admins to manage users.
     */
    match /users/{userId} {
      allow get, update: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId);
      allow list, delete: if isAdmin();
    }

    // ----------------------------------------------------------------------
    // Public Content Collections
    // ----------------------------------------------------------------------

    /**
     * @description Publicly readable collections that are managed by admins.
     */
    match /announcements/{announcementId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }
    
    match /events/{eventId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /faqs/{faqId} {
        allow get, list: if true;
        allow create, update, delete: if isAdmin();
    }

    match /projects/{projectId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    // ----------------------------------------------------------------------
    // User-Owned Subcollections
    // ----------------------------------------------------------------------
    match /users/{userId}/feedback/{feedbackId} {
      allow create: if isOwner(userId);
      allow read, update, delete: if isOwner(userId) || isAdmin();
    }


    // ----------------------------------------------------------------------
    // Admin-Only Collections
    // ----------------------------------------------------------------------
    match /logs/{logId} {
      allow read, write: if isAdmin();
    }

    match /archives/{archiveId} {
      allow read, write: if isAdmin();
    }
  }
}
    